# =============================================================================
# HK Legal Chatbot — Backend Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# ── Secrets (REQUIRED) ───────────────────────────────────────────────────────
DEEPSEEK_API_KEY=
QDRANT_URL=https://your-cluster-url.qdrant.io
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=hk_legal_chunks

# ── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=qwen3.5:9b
# OLLAMA_HOST_GATEWAY=             # WSL host override for Ollama discovery
# OLLAMA_AUTO_START=1              # Auto-start Ollama if not running

# ── Chat Runtime ─────────────────────────────────────────────────────────────
# CHAT_VECTOR_TOP_K=50
# CHAT_RERANK_TOP_K=10
# CHAT_MIN_SECTION_FLOOR=5
# CHAT_MULTI_HYDE_K_PER_QUERY=3
# CHAT_MULTI_HYDE_RERANK_TOP_K=5
# HYDE_NUM_GENERATIONS=3

# ── Embedding ────────────────────────────────────────────────────────────────
EMBEDDING_REQUIRE_TENSORRT=1
EMBEDDING_TRT_MAX_WORKSPACE_SIZE=536870912
EMBEDDING_MAX_LENGTH=768
EMBEDDING_TRT_FP16=1
EMBEDDING_STRICT_FP16=1
# EMBEDDING_DIMENSION=1024
# EMBEDDING_LEGACY_PRECISION_POLICY=warn
# EMBEDDING_TRT_MIN_SUBGRAPH_SIZE=5
# EMBEDDING_TRT_MAX_PARTITION_ITERATIONS=200
# EMBEDDING_TRT_AUX_STREAMS=0

# ── Reranker ─────────────────────────────────────────────────────────────────
RERANKER_MODEL_DIR=zerank-1-small
RERANKER_ONNX_FILE=model_fp16.onnx
RERANKER_STRICT_ONNX_FILE=1
RERANKER_STRICT_MISTRAL_REGEX_FIX=0
RERANKER_FORCE_CPU=0
RERANKER_DISABLE_RUNTIME_CPU_FALLBACK=1
RERANKER_REQUIRE_TENSORRT=0
RERANKER_MICRO_BATCH_SIZE=1
RERANKER_FIXED_BATCH_SIZE=1
RERANKER_MAX_LENGTH=768
RERANKER_FIXED_SHAPE_PADDING=1
# RERANKER_ORT_LOG_SEVERITY_LEVEL=2
RERANKER_TRT_MAX_WORKSPACE_SIZE=134217728
RERANKER_TRT_MIN_SUBGRAPH_SIZE=20
RERANKER_TRT_MAX_PARTITION_ITERATIONS=100
RERANKER_TRT_BUILDER_OPT_LEVEL=1
RERANKER_TRT_CONTEXT_MEMORY_SHARING_ENABLE=0
RERANKER_TRT_OP_TYPES_TO_EXCLUDE=Range
RERANKER_TRT_PROFILE_MIN_SHAPES=
RERANKER_TRT_PROFILE_OPT_SHAPES=
RERANKER_TRT_PROFILE_MAX_SHAPES=

# ── Ingestion ────────────────────────────────────────────────────────────────
INGEST_INFLIGHT_EMBED_JOBS=3
INGEST_WORKER_MICROBATCH_MAX_TEXTS=96
INGEST_WORKER_MICROBATCH_WAIT_SECONDS=0.05
INGEST_WORKER_EMBED_SUBBATCH_TEXTS=24
INGEST_WORKER_MIN_EMBED_SUBBATCH_TEXTS=4
# INGEST_EMBEDDING_TIMEOUT_SECONDS=300
# EMBEDDING_CLEAR_TRT_CACHE=0

# ── Parser ───────────────────────────────────────────────────────────────────
# PARSER_EMBEDDING_TIMEOUT_SECONDS=300
# PARSER_EMBEDDING_BATCH_SIZE=64

# ── LLM Evaluation ──────────────────────────────────────────────────────────
# HK_LEGAL_EVAL_MODEL=qwen3.5:9b
# HK_LEGAL_EVAL_JUDGE_MODEL=deepseek-chat
# HK_LEGAL_EVAL_LLM_CONCURRENCY=6
# HK_LEGAL_EVAL_QUERIES_PATH=        # Override queries file location
# HK_LEGAL_EVAL_OUTPUT_PATH=         # Override output file location
# HK_LEGAL_EVAL_STDOUT_JSON=0
HK_LEGAL_EVAL_COMPARE_RERANKERS=0
HK_LEGAL_EVAL_RERANKER_FORCE_CPU=0
HK_LEGAL_EVAL_RERANKER_REQUIRE_TENSORRT=0
HK_LEGAL_EVAL_RERANKER_VARIANTS=zerank-1-small:model_fp16.onnx
HK_LEGAL_EVAL_EMBEDDING_TRT_MAX_WORKSPACE_SIZE=2147483648
HK_LEGAL_EVAL_RERANKER_TRT_MAX_WORKSPACE_SIZE=3221225472
HK_LEGAL_EVAL_VECTOR_TOP_K=30
HK_LEGAL_EVAL_RERANK_TOP_K=5
HK_LEGAL_EVAL_QUERY_ID_PATTERN=q\d+_1
HK_LEGAL_EVAL_PROGRESS_ONLY=1
HK_LEGAL_EVAL_HYDE_TIMEOUT_SECONDS=180
HK_LEGAL_EVAL_RETRIEVAL_TIMEOUT_SECONDS=0   # 0 = no timeout
HK_LEGAL_EVAL_ANSWER_TIMEOUT_SECONDS=300
HK_LEGAL_EVAL_JUDGE_TIMEOUT_SECONDS=300
# HK_LEGAL_EVAL_SKIP_SOURCE_USEFULNESS=1
# HK_LEGAL_EVAL_INCLUDE_NO_RAG_BASELINE=1
# HK_LEGAL_EVAL_INCLUDE_CLASSIC_VECTOR_STRATEGIES=0
# HK_LEGAL_EVAL_INCLUDE_MULTI_HYDE=1
# HK_LEGAL_EVAL_MULTI_HYDE_K_PER_QUERY=3
# HK_LEGAL_EVAL_MULTI_HYDE_RERANK_TOP_K=5
